[Unit]
Description=UQM Backend (Spring Boot)
After=network-online.target mysql.service redis-server.service
Wants=network-online.target mysql.service redis-server.service
PartOf=uqm.target

[Service]
Type=simple
Environment=TZ=Asia/Shanghai
WorkingDirectory=/home/golden/university-quality-monitor/backend
ExecStart=/home/golden/university-quality-monitor/scripts/uqm-backend-start.sh
Restart=always
RestartSec=10
TimeoutStartSec=180
StandardOutput=append:/home/golden/university-quality-monitor/logs/uqm-backend.log
StandardError=append:/home/golden/university-quality-monitor/logs/uqm-backend.log

[Install]
WantedBy=uqm.target default.target
